# ═══════════════════════════════════════════════════
# CAREER OS BACKEND — Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to git
# ═══════════════════════════════════════════════════

# ── Anthropic ──────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── Adzuna Job Search API ──────────────────────────
# Free: 500 calls/day — no credit card needed
# Sign up at: https://developer.adzuna.com/signup
# After signup go to: https://developer.adzuna.com/admin/applications
# Create an app → copy App ID and App Key below
ADZUNA_APP_ID=YOUR_ADZUNA_APP_ID
ADZUNA_APP_KEY=YOUR_ADZUNA_APP_KEY

# ── Server ─────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ───────────────────────────────────────────
# Add your frontend URL when deploying (Railway/Render auto-sets PORT)
# FRONTEND_URL=https://your-frontend.com
