# ─────────────────────────────────────────────────────────────
# Career OS Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=8080

# ── PostgreSQL ────────────────────────────────────────────────
# Format: postgresql://<role>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql://career_app:CHANGE_ME@localhost:5432/career_os

# ── Anthropic API ─────────────────────────────────────────────
# Required for: Indeed MCP primary path, Pooja web-search service
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Serper.dev ────────────────────────────────────────────────
# Required for: DJ monitor web search (google.serper.dev)
# Get a key at: https://serper.dev
SERPER_API_KEY=CHANGE_ME

# ── Indeed MCP ────────────────────────────────────────────────
# Optional — enables the Indeed primary path for DJ's US job search.
# If unset, the US pipeline falls back to Adzuna silently.
INDEED_MCP_URL=https://mcp.indeed.com/v1
INDEED_MCP_TOKEN=CHANGE_ME

# ── Adzuna ────────────────────────────────────────────────────
# Required for: all non-US regions (Europe, India) and the US fallback path.
# Free tier: https://developer.adzuna.com
ADZUNA_APP_ID=CHANGE_ME
ADZUNA_APP_KEY=CHANGE_ME

# ── Cache ─────────────────────────────────────────────────────
# TTL in seconds for in-memory job cache (default: 2700 = 45 min)
CACHE_TTL=2700
